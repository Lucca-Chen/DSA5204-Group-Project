#!/bin/bash
#PBS -N t3-eval
#PBS -q batch_gpu
#PBS -l select=1:ncpus=8:ngpus=1:mem=64gb:gpu-type=nvidia
#PBS -l walltime=12:00:00
#PBS -j oe

set -euo pipefail

REPO_ROOT="${REPO_ROOT:-/nfs/home/svu/e1553870/DSA5204-Group-Project}"
VENV_PATH="${VENV_PATH:-${REPO_ROOT}/.venv}"
RUNS_ROOT="${RUNS_ROOT:-/scratch/e1553870/DSA5204-Group-Project/runs_table3}"
OUTPUT_ROOT="${OUTPUT_ROOT:-/scratch/e1553870/DSA5204-Group-Project/output/table3_eval}"
RESULT_ROOT="${RESULT_ROOT:-/scratch/e1553870/DSA5204-Group-Project/grounding_results}"

MODEL_TYPE="${MODEL_TYPE:-checkpoint}"   # checkpoint or vanilla_clip
MODEL_VARIANT="${MODEL_VARIANT:-laps}"
RUN_SUFFIX="${RUN_SUFFIX:-_clip_t3}"
RUN_NAME="${RUN_NAME:-f30k_${MODEL_VARIANT}${RUN_SUFFIX}}"
CHECKPOINT_PATH="${CHECKPOINT_PATH:-auto}"
CLIP_MODEL_NAME="${CLIP_MODEL_NAME:-openai/clip-vit-base-patch16}"
REF_ROOT="${REF_ROOT:-/scratch/e1553870/datasets/refcoco_raw}"
COCO_IMG_PATH="${COCO_IMG_PATH:-/scratch/e1553870/datasets/coco-images}"
DATASET_NAME="${DATASET_NAME:-all}"      # all / refcoco / refcoco+ / refcocog
GROUNDING_ALPHA="${GROUNDING_ALPHA:-1.0}"
GROUNDING_BETA="${GROUNDING_BETA:-0.0}"
GROUNDING_IOU_THRESH="${GROUNDING_IOU_THRESH:-0.5}"
GROUNDING_SPLIT_BY="${GROUNDING_SPLIT_BY:-}"
GPU_ID="${GPU_ID:-0}"
EXTRA_ARGS="${EXTRA_ARGS:-}"

mkdir -p "${OUTPUT_ROOT}" "${RESULT_ROOT}"

LOG_NAME="${MODEL_TYPE}_${RUN_NAME}"
if [[ "${MODEL_TYPE}" == "vanilla_clip" ]]; then
  LOG_NAME="vanilla_clip_${DATASET_NAME}"
fi

LOG_PREFIX="${OUTPUT_ROOT}/${LOG_NAME}-${PBS_JOBID:-manual}"
exec > >(tee -a "${LOG_PREFIX}.out") 2> >(tee -a "${LOG_PREFIX}.err" >&2)

echo "[eval_table3_grounding] start=$(date -Is)"
echo "[eval_table3_grounding] host=$(hostname)"
echo "[eval_table3_grounding] jobid=${PBS_JOBID:-manual}"
echo "[eval_table3_grounding] model_type=${MODEL_TYPE} run=${RUN_NAME}"

if [[ -n "${PBS_O_WORKDIR:-}" ]]; then
  cd "${PBS_O_WORKDIR}"
fi

if [[ ! -f "${VENV_PATH}/bin/activate" ]]; then
  echo "Missing virtualenv at ${VENV_PATH}" >&2
  exit 1
fi

source "${VENV_PATH}/bin/activate"

export PYTHONUNBUFFERED=1
export PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION="${PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION:-python}"
export TMPDIR="${TMPDIR:-/scratch/e1553870/tmp}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-/scratch/e1553870/.cache}"
export HF_HOME="${HF_HOME:-/scratch/e1553870/.cache/huggingface}"
export TORCH_HOME="${TORCH_HOME:-/scratch/e1553870/.cache/torch}"

mkdir -p "${TMPDIR}" "${XDG_CACHE_HOME}" "${HF_HOME}" "${TORCH_HOME}"

cd "${REPO_ROOT}"

echo "[eval_table3_grounding] python=$(command -v python)"
python --version
nvidia-smi -L || true

if [[ "${CHECKPOINT_PATH}" == "auto" ]]; then
  CHECKPOINT_PATH="${RUNS_ROOT}/${RUN_NAME}/model_best.pth"
fi

OUTPUT_JSON="${RESULT_ROOT}/${LOG_NAME}.json"

CMD=(
  python grounding_eval.py
  --model_type "${MODEL_TYPE}"
  --gpu-id "${GPU_ID}"
  --clip_model_name "${CLIP_MODEL_NAME}"
  --ref_root "${REF_ROOT}"
  --coco_img_path "${COCO_IMG_PATH}"
  --dataset "${DATASET_NAME}"
  --grounding_alpha "${GROUNDING_ALPHA}"
  --grounding_beta "${GROUNDING_BETA}"
  --grounding_iou_thresh "${GROUNDING_IOU_THRESH}"
  --output_json "${OUTPUT_JSON}"
)

if [[ -n "${GROUNDING_SPLIT_BY}" ]]; then
  CMD+=(--grounding_split_by "${GROUNDING_SPLIT_BY}")
fi

if [[ "${MODEL_TYPE}" == "checkpoint" ]]; then
  if [[ ! -f "${CHECKPOINT_PATH}" ]]; then
    echo "Missing checkpoint at ${CHECKPOINT_PATH}" >&2
    exit 1
  fi
  CMD+=(--checkpoint "${CHECKPOINT_PATH}")
fi

if [[ -n "${EXTRA_ARGS}" ]]; then
  read -r -a EXTRA_ARRAY <<< "${EXTRA_ARGS}"
  CMD+=("${EXTRA_ARRAY[@]}")
fi

echo "[eval_table3_grounding] command=${CMD[*]}"
"${CMD[@]}"

echo "[eval_table3_grounding] result_json=${OUTPUT_JSON}"
echo "[eval_table3_grounding] done=$(date -Is)"

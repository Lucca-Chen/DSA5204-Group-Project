#!/bin/bash
#PBS -N extra-eval
#PBS -q batch_gpu
#PBS -l select=1:ncpus=8:ngpus=1:mem=64gb:gpu-type=nvidia
#PBS -l walltime=06:00:00
#PBS -j oe

set -euo pipefail

REPO_ROOT="${REPO_ROOT:-/nfs/home/svu/e1553870/DSA5204-Group-Project}"
VENV_PATH="${VENV_PATH:-${REPO_ROOT}/.venv}"
RUNS_ROOT="${RUNS_ROOT:-/scratch/e1553870/DSA5204-Group-Project/runs_extra}"
OUTPUT_ROOT="${OUTPUT_ROOT:-/scratch/e1553870/DSA5204-Group-Project/output/extra_eval}"

DATASET="${DATASET:-iapr_tc12}"
MODEL_VARIANT="${MODEL_VARIANT:-laps}"
VIT_TYPE="${VIT_TYPE:-vit}"
RUN_SUFFIX="${RUN_SUFFIX:-}"
RUN_NAME="${RUN_NAME:-${DATASET}_${MODEL_VARIANT}_${VIT_TYPE}${RUN_SUFFIX}}"
MODEL_PATH="${MODEL_PATH:-auto}"
DATA_PATH="${DATA_PATH:-data/}"
TEST_SPLIT="${TEST_SPLIT:-test}"
GPU_ID="${GPU_ID:-0}"
SAVE_RESULTS="${SAVE_RESULTS:-1}"

mkdir -p "${OUTPUT_ROOT}"
LOG_PREFIX="${OUTPUT_ROOT}/${RUN_NAME}-${PBS_JOBID:-manual}"
exec > >(tee -a "${LOG_PREFIX}.out") 2> >(tee -a "${LOG_PREFIX}.err" >&2)

if [[ -n "${PBS_O_WORKDIR:-}" ]]; then
  cd "${PBS_O_WORKDIR}"
fi

source "${VENV_PATH}/bin/activate"

export PYTHONUNBUFFERED=1
export PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION="${PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION:-python}"
export TMPDIR="${TMPDIR:-/scratch/e1553870/tmp}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-/scratch/e1553870/.cache}"
export HF_HOME="${HF_HOME:-/scratch/e1553870/.cache/huggingface}"
export TORCH_HOME="${TORCH_HOME:-/scratch/e1553870/.cache/torch}"

mkdir -p "${TMPDIR}" "${XDG_CACHE_HOME}" "${HF_HOME}" "${TORCH_HOME}"

cd "${REPO_ROOT}"

if [[ "${MODEL_PATH}" == "auto" ]]; then
  MODEL_PATH="${RUNS_ROOT}/${RUN_NAME}/model_best.pth"
fi

CMD=(
  python eval.py
  --dataset "${DATASET}"
  --data_path "${DATA_PATH}"
  --gpu-id "${GPU_ID}"
  --split "${TEST_SPLIT}"
  --save_results "${SAVE_RESULTS}"
  --model_paths "${MODEL_PATH}"
)

echo "[eval_extra_dataset_shared_backbone] command=${CMD[*]}"
"${CMD[@]}"
